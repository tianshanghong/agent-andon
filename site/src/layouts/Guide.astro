---
// Branded layout for an evergreen intent guide — same dark palette + self-hosted IBM Plex as the
// blog, tuned for long-form reading. Emits Article (+ optional HowTo) JSON-LD + canonical + hreflang.
import Analytics from "../components/Analytics.astro";
const { title, description, updated, howto, slug } = Astro.props;
const BASE = "https://agentandon.com";
const canonical = `${BASE}/guides/${slug}/`;
const iso = (d) => new Date(d).toISOString().slice(0, 10);
const human = (d) =>
  new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
const ld = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  ...(updated ? { dateModified: iso(updated) } : {}),
  author: { "@type": "Organization", name: "Agent Andon" },
  publisher: { "@type": "Organization", name: "Agent Andon" },
  mainEntityOfPage: canonical,
  image: `${BASE}/social-card.png`,
};
const howtoLd = howto && howto.length
  ? {
      "@context": "https://schema.org",
      "@type": "HowTo",
      name: title,
      description,
      step: howto.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.name, text: s.text })),
    }
  : null;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title} — Agent Andon</title>
<meta name="description" content={description}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="article">
<meta property="og:url" content={canonical}>
<meta property="og:image" content={`${BASE}/social-card.png`}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={`${BASE}/social-card.png`}>
<meta name="theme-color" content="#0c0d10">
<link rel="canonical" href={canonical}>
<link rel="alternate" hreflang="en" href={canonical}>
<link rel="alternate" hreflang="x-default" href={canonical}>
<script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
{howtoLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(howtoLd)} />}
<Analytics />
<style is:inline>
  @font-face{font-family:'IBM Plex Sans';font-style:normal;font-weight:400 700;font-display:swap;src:url(/fonts/ibm-plex-sans.woff2) format('woff2')}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/ibm-plex-mono-400.woff2) format('woff2')}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/ibm-plex-mono-600.woff2) format('woff2')}
  :root{
    --bg:#0c0d10; --surface:#15171c; --surface-2:#101217; --hairline:#23262e; --hairline-soft:#1b1e25;
    --text:#e7eaef; --muted:#878e9b; --faint:#565d69;
    --working:#5478c4; --waiting:#ffaa1a; --done:#3aa86b; --error:#ff463b;
    --mono:'IBM Plex Mono',ui-monospace,monospace; --sans:'IBM Plex Sans',-apple-system,system-ui,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.7;-webkit-font-smoothing:antialiased}
  a{color:var(--done);text-decoration:none} a:hover{text-decoration:underline}
  ::selection{background:var(--waiting);color:#1b1304}
  .strip{position:fixed;top:0;left:0;right:0;height:4px;display:flex;z-index:50}
  .strip i{flex:1} .strip .e{background:var(--error)} .strip .w{background:var(--waiting)} .strip .d{background:var(--done)} .strip .k{background:var(--working)}
  nav{position:sticky;top:0;z-index:40;backdrop-filter:blur(10px);background:color-mix(in srgb,var(--bg) 78%,transparent);border-bottom:1px solid var(--hairline-soft)}
  nav .wrap{max-width:760px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:58px}
  .logo{font-family:var(--mono);font-weight:700;letter-spacing:.26em;font-size:14px;color:var(--text)}
  .logo .dim{color:var(--faint)}
  .navlinks{display:flex;gap:22px;font-family:var(--mono);font-size:13px;letter-spacing:.04em}
  .navlinks a{color:var(--muted)} .navlinks a:hover{color:var(--text);text-decoration:none}
  .wrap{max-width:760px;margin:0 auto;padding:0 24px}
  article.wrap{padding:64px 24px 96px}
  .eyebrow{font-family:var(--mono);font-size:12.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint)}
  h1{font-size:clamp(30px,5vw,46px);line-height:1.1;font-weight:700;letter-spacing:-.02em;margin:14px 0 0}
  .meta{font-family:var(--mono);font-size:13px;color:var(--muted);margin-top:18px}
  .prose{margin-top:40px;font-size:18px;color:#d6dae1}
  .prose > * + *{margin-top:22px}
  .prose h2{font-size:25px;font-weight:700;letter-spacing:-.01em;color:var(--text);margin-top:46px;line-height:1.25}
  .prose strong{color:var(--text);font-weight:600}
  .prose code{font-family:var(--mono);font-size:.86em;background:var(--surface);border:1px solid var(--hairline-soft);border-radius:5px;padding:1px 6px;color:var(--text)}
  .prose pre{font-family:var(--mono);font-size:14px;background:var(--surface-2);border:1px solid var(--hairline);border-radius:11px;padding:16px 18px;overflow-x:auto;line-height:1.6}
  .prose pre code{background:none;border:0;padding:0;font-size:inherit;color:var(--muted)}
  .prose ul{padding-left:0;list-style:none;display:flex;flex-direction:column;gap:12px}
  .prose ul li{position:relative;padding-left:22px;color:var(--muted)}
  .prose ul li::before{content:"";position:absolute;left:2px;top:.7em;width:6px;height:6px;border-radius:50%;background:var(--done)}
  .prose ul li strong{color:var(--text)}
  .prose ol{padding-left:22px;display:flex;flex-direction:column;gap:12px;color:var(--muted)}
  .prose ol li strong{color:var(--text)}
  footer{border-top:1px solid var(--hairline-soft);padding:40px 0 64px}
  footer .wrap{display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;font-family:var(--mono);font-size:12.5px;color:var(--faint)}
  footer a{color:var(--muted)}
</style>
</head>
<body>
<div class="strip"><i class="e"></i><i class="w"></i><i class="d"></i><i class="k"></i></div>
<nav><div class="wrap">
  <a href="/" class="logo">🚦 ANDON<span class="dim"> /行灯</span></a>
  <div class="navlinks"><a href="/guides/">Guides</a><a href="/docs/running/">Docs</a><a href="https://github.com/tianshanghong/agent-andon">GitHub</a></div>
</div></nav>
<article class="wrap">
  <div class="eyebrow">Agent Andon · Guide</div>
  <h1>{title}</h1>
  {updated && <div class="meta">Updated {human(updated)}</div>}
  <div class="prose"><slot /></div>
</article>
<footer><div class="wrap">
  <span>Open source under AGPL-3.0 · © 2026 wwang · cookieless analytics on this site</span>
  <span><a href="/">agentandon.com</a> · <a href="https://github.com/tianshanghong/agent-andon">GitHub</a></span>
</div></footer>
</body>
</html>
