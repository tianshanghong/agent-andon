---
// Locale-aware index for the /guides/ section. Same dark palette as the guide pages.
// `guides` is the already-sorted list for this locale (en ids have no slash; locale ids
// are "<locale>/<slug>"). The English DESC is reused for every locale for now.
import Analytics from "../components/Analytics.astro";
import { LANG, LOCALES, ui } from "../i18n/ui";
const { locale = "en", guides } = Astro.props;
const BASE = "https://agentandon.com";
const DESC = "Practical how-to guides for watching your Claude Code and Codex agents — get notified when one finishes or needs you, monitor several at once, and turn a spare screen into a status board.";
const indexPath = locale === "en" ? "/guides/" : `/${locale}/guides/`;
const canonical = `${BASE}${indexPath}`;
const idxHref = (code) => `${BASE}${code === "en" ? "/guides/" : `/${code}/guides/`}`;
// Strip the locale prefix from a locale guide id; en ids have none.
const guideHref = (g) =>
  locale === "en" ? `/guides/${g.id}/` : `/${locale}/guides/${g.id.split("/").slice(1).join("/")}/`;
const blogLabel = ui[locale]?.ftBlog ?? ui.en.ftBlog;
const docsLabel = ui[locale]?.ftDocs ?? ui.en.ftDocs;
const docsHref = locale === "en" ? "/docs/running/" : `/${locale}/docs/running/`;
---
<!doctype html>
<html lang={LANG[locale]}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Guides — Agent Andon</title>
<meta name="description" content={DESC}>
<meta property="og:title" content="Agent Andon — Guides">
<meta property="og:description" content={DESC}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:image" content={`${BASE}/social-card.png`}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Agent Andon — Guides">
<meta name="twitter:description" content={DESC}>
<meta name="twitter:image" content={`${BASE}/social-card.png`}>
<meta name="theme-color" content="#0c0d10">
<link rel="canonical" href={canonical}>
{LOCALES.map((code) => <link rel="alternate" hreflang={LANG[code]} href={idxHref(code)} />)}
<link rel="alternate" hreflang="x-default" href={idxHref("en")}>
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Agent Andon — Guides",
  url: canonical,
  hasPart: guides.map((g) => ({
    "@type": "Article",
    headline: g.data.title,
    description: g.data.description,
    url: `${BASE}${guideHref(g)}`,
  })),
})} />
<style is:inline>
  @font-face{font-family:'IBM Plex Sans';font-style:normal;font-weight:400 700;font-display:swap;src:url(/fonts/ibm-plex-sans.woff2) format('woff2')}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/ibm-plex-mono-400.woff2) format('woff2')}
  :root{--bg:#0c0d10;--surface-2:#101217;--hairline:#23262e;--hairline-soft:#1b1e25;--text:#e7eaef;--muted:#878e9b;--faint:#565d69;--done:#3aa86b;--error:#ff463b;--waiting:#ffaa1a;--working:#5478c4;--mono:'IBM Plex Mono',ui-monospace,monospace;--sans:'IBM Plex Sans',-apple-system,system-ui,sans-serif}
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--waiting);color:#1b1304}
  .strip{position:fixed;top:0;left:0;right:0;height:4px;display:flex;z-index:50}
  .strip i{flex:1} .strip .e{background:var(--error)} .strip .w{background:var(--waiting)} .strip .d{background:var(--done)} .strip .k{background:var(--working)}
  nav{position:sticky;top:0;z-index:40;backdrop-filter:blur(10px);background:color-mix(in srgb,var(--bg) 78%,transparent);border-bottom:1px solid var(--hairline-soft)}
  nav .wrap{max-width:760px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:58px}
  .logo{font-family:var(--mono);font-weight:700;letter-spacing:.26em;font-size:14px} .logo .dim{color:var(--faint)}
  .navlinks{display:flex;gap:22px;font-family:var(--mono);font-size:13px}.navlinks a{color:var(--muted)}.navlinks a:hover{color:var(--text)}
  .wrap{max-width:760px;margin:0 auto;padding:0 24px}
  header.h{padding:64px 0 8px}
  header.h .eyebrow{font-family:var(--mono);font-size:12.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint)}
  header.h h1{font-size:clamp(32px,5vw,46px);font-weight:700;letter-spacing:-.02em;margin-top:12px}
  header.h p{color:var(--muted);font-size:18px;margin-top:14px;max-width:36em}
  .posts{padding:36px 0 96px;display:flex;flex-direction:column;gap:2px}
  .post{display:block;padding:24px;border:1px solid transparent;border-radius:12px;transition:.2s}
  .post:hover{border-color:var(--hairline);background:var(--surface-2)}
  .post h2{font-size:22px;font-weight:600;letter-spacing:-.01em}
  .post p{color:var(--muted);font-size:15.5px;margin-top:8px;max-width:46em}
  .post .more{color:var(--done);font-family:var(--mono);font-size:13px;margin-top:12px;display:inline-block}
  .empty{padding:36px 0 96px;color:var(--muted)}
  footer{border-top:1px solid var(--hairline-soft);padding:36px 0 64px;margin-top:24px}
  footer .wrap{display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;font-family:var(--mono);font-size:12.5px;color:var(--faint)}
  footer a{color:var(--muted)}
</style>
<Analytics />
</head>
<body>
<div class="strip"><i class="e"></i><i class="w"></i><i class="d"></i><i class="k"></i></div>
<nav><div class="wrap">
  <a href="/" class="logo">🚦 ANDON<span class="dim"> /行灯</span></a>
  <div class="navlinks"><a href="/blog/">{blogLabel}</a><a href={docsHref}>{docsLabel}</a><a href="https://github.com/tianshanghong/agent-andon">GitHub</a></div>
</div></nav>
<header class="h"><div class="wrap">
  <div class="eyebrow">Agent Andon · Guides</div>
  <h1>Guides</h1>
  <p>{DESC}</p>
</div></header>
<main class="wrap">
  {guides.length === 0 ? (
    <div class="empty">Guides are on the way.</div>
  ) : (
    <div class="posts">
      {guides.map((g) => (
        <a class="post" href={guideHref(g)}>
          <h2>{g.data.title}</h2>
          <p>{g.data.description}</p>
          <span class="more">Read →</span>
        </a>
      ))}
    </div>
  )}
</main>
<footer><div class="wrap">
  <span>Open source under AGPL-3.0 · © 2026 wwang · cookieless analytics on this site</span>
  <span><a href="/">agentandon.com</a> · <a href="https://github.com/tianshanghong/agent-andon">GitHub</a></span>
</div></footer>
</body>
</html>
