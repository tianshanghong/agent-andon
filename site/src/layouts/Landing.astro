---
import { ui, LOCALES, LANG, type Locale } from "../i18n/ui";
const { locale } = Astro.props as { locale: Locale };
const t = ui[locale];
const BASE = "https://agentandon.com";
const urlFor = (l: string): string => (l === "en" ? `${BASE}/` : `${BASE}/${l}/`);
const canonical = urlFor(locale);
---
<!doctype html>
<html lang={LANG[locale]}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{t.title}</title>
<meta name="description" content={t.desc}>
<meta property="og:title" content={t.ogTitle}>
<meta property="og:description" content={t.ogDesc}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:image" content="https://agentandon.com/social-card.png">
<meta property="og:image:width" content="1280">
<meta property="og:image:height" content="640">
<meta property="og:image:alt" content={t.ogAlt}>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={t.ogTitle}>
<meta name="twitter:description" content={t.ogDesc}>
<meta name="twitter:image" content="https://agentandon.com/social-card.png">
<meta name="theme-color" content="#0c0d10">
<link rel="canonical" href={canonical}>
{LOCALES.map((l) => (<link rel="alternate" hreflang={LANG[l]} href={urlFor(l)} />))}
<link rel="alternate" hreflang="x-default" href={urlFor("en")} />
<style is:inline>
  /* Self-hosted IBM Plex (latin subset, woff2) in site/fonts/ — no external font CDN.
     Sans is a variable file (weight range); Mono ships one file per weight. */
  @font-face{font-family:'IBM Plex Sans';font-style:normal;font-weight:400 700;font-display:swap;src:url(/fonts/ibm-plex-sans.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/ibm-plex-mono-400.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/ibm-plex-mono-600.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
  @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/ibm-plex-mono-700.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
  :root{
    --bg:#0c0d10; --surface:#15171c; --surface-2:#101217;
    --hairline:#23262e; --hairline-soft:#1b1e25;
    --text:#e7eaef; --muted:#878e9b; --faint:#565d69;
    --working:#5478c4; --waiting:#ffaa1a; --done:#3aa86b; --error:#ff463b; --idle:#3b424d;
    --mono:'IBM Plex Mono',ui-monospace,monospace;
    --sans:'IBM Plex Sans',-apple-system,system-ui,sans-serif;
    --maxw:1080px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:var(--bg); color:var(--text); font-family:var(--sans); line-height:1.6;
    -webkit-font-smoothing:antialiased; overflow-x:hidden;
  }
  a{color:inherit}
  ::selection{background:var(--waiting);color:#1b1304}

  /* signal strip — the andon tower light, pinned to the top */
  .strip{position:fixed;top:0;left:0;right:0;height:4px;display:flex;z-index:50}
  .strip i{flex:1}
  .strip .e{background:var(--error)} .strip .w{background:var(--waiting)}
  .strip .d{background:var(--done)} .strip .k{background:var(--working)}

  /* atmospheric grid, faded from the top-left */
  .grid{position:fixed;inset:0;z-index:-1;opacity:.6;pointer-events:none;
    background-image:linear-gradient(var(--hairline-soft) 1px,transparent 1px),linear-gradient(90deg,var(--hairline-soft) 1px,transparent 1px);
    background-size:46px 46px;
    -webkit-mask-image:radial-gradient(130% 95% at 18% -10%,#000,transparent 66%);
            mask-image:radial-gradient(130% 95% at 18% -10%,#000,transparent 66%)}

  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}
  section{padding:84px 0}

  /* ---- nav ---- */
  nav{position:sticky;top:0;z-index:40;backdrop-filter:blur(10px);
    background:color-mix(in srgb,var(--bg) 78%,transparent);border-bottom:1px solid var(--hairline-soft)}
  nav .wrap{display:flex;align-items:center;justify-content:space-between;height:60px}
  .logo{font-family:var(--mono);font-weight:700;letter-spacing:.28em;font-size:15px}
  .logo .dim{color:var(--faint)}
  .navlinks{display:flex;gap:26px;align-items:center;font-family:var(--mono);font-size:13px;letter-spacing:.04em}
  .navlinks a{color:var(--muted);text-decoration:none;transition:color .2s}
  .navlinks a:hover{color:var(--text)}
  .navlinks .star{color:var(--text);border:1px solid var(--hairline);padding:7px 13px;border-radius:7px}
  .navlinks .star:hover{border-color:var(--waiting);color:var(--waiting)}
  @media(max-width:640px){.navlinks a:not(.star){display:none}}

  /* ---- hero ---- */
  .hero{padding-top:78px;display:grid;grid-template-columns:1.05fr .95fr;gap:60px;align-items:center}
  .kicker{font-family:var(--mono);font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:var(--faint)}
  .kicker b{color:var(--done);font-weight:600}
  h1{font-size:clamp(40px,6vw,68px);line-height:1.02;font-weight:700;letter-spacing:-.022em;margin:20px 0 0}
  h1 b{color:var(--waiting);font-weight:700}
  .lede{color:var(--muted);font-size:19px;line-height:1.55;margin-top:24px;max-width:30em}
  .lede b{color:var(--text);font-weight:600}

  .cmd{position:relative;margin-top:13px;max-width:560px;border:1px solid var(--done);border-radius:11px;
    background:var(--surface-2);font-family:var(--mono);font-size:13.5px;
    box-shadow:0 0 0 4px color-mix(in srgb,var(--done) 9%,transparent)}
  .cmd code{display:block;padding:16px 18px;white-space:pre;overflow-x:auto;line-height:2}
  .cmd code .p{color:var(--done);user-select:none;margin-right:2px}
  .cmd button{position:absolute;top:9px;right:9px;border:1px solid var(--hairline-soft);background:var(--surface);
    color:var(--muted);font-family:var(--mono);font-size:11px;letter-spacing:.08em;padding:6px 11px;
    border-radius:6px;cursor:pointer;transition:.2s}
  .cmd button:hover{color:var(--text);border-color:var(--muted)}
  .cmd button.ok{color:var(--done);border-color:var(--done)}
  .hint{font-family:var(--mono);font-size:12.5px;color:var(--faint);margin-top:12px;max-width:42em;line-height:1.7}

  .cta{margin-top:30px;display:flex;gap:14px;flex-wrap:wrap}
  .btn{font-family:var(--mono);font-size:13.5px;letter-spacing:.03em;text-decoration:none;padding:12px 18px;
    border-radius:9px;border:1px solid var(--hairline);transition:.2s;display:inline-flex;align-items:center;gap:9px}
  .btn.ghost{color:var(--text)}
  .btn.ghost:hover{border-color:var(--muted);transform:translateY(-1px)}
  /* hero collapses to one column on narrow screens (text, then the board) */
  @media(max-width:820px){.hero{grid-template-columns:1fr;gap:34px;padding-top:50px}}

  /* board mock — the hero centerpiece */
  .board{display:flex;flex-direction:column;gap:12px}
  .card{border:1px solid var(--hairline);border-radius:11px;padding:15px 18px;position:relative;overflow:hidden;
    background:color-mix(in srgb,var(--cc) 8%,var(--surface))}
  .card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--cc)}
  .card .st{font-family:var(--mono);font-weight:600;font-size:12px;letter-spacing:.13em;text-transform:uppercase;color:var(--cc)}
  .card .nm{font-weight:600;font-size:20px;margin-top:3px;letter-spacing:-.01em}
  .card .msg{font-family:var(--mono);font-size:12.5px;color:var(--muted);margin-top:4px}
  .card.k{--cc:var(--working)} .card.d{--cc:var(--done)}
  .card.w{--cc:var(--waiting)} .card.e{--cc:var(--error)}
  /* urgent cards go solid + pulse, like the real board */
  .card.e,.card.w{border-color:transparent}
  .card.e::before,.card.w::before{opacity:0}
  .card.e{background:var(--error)} .card.e .st,.card.e .nm{color:#fff4f3} .card.e .msg{color:#ffd9d6}
  .card.w{background:var(--waiting)} .card.w .st,.card.w .nm{color:#1b1304} .card.w .msg{color:#3a2c08}
  /* pulse cards also need the rise reveal — combine both (a single `animation` shorthand would clobber rise) */
  .card.pulse{animation:rise .7s cubic-bezier(.2,.7,.2,1) forwards, pulse 2.4s ease-in-out infinite}
  @keyframes pulse{0%,100%{box-shadow:0 0 0 0 color-mix(in srgb,var(--cc) 55%,transparent)}50%{box-shadow:0 0 0 7px transparent}}
  @media(prefers-reduced-motion:reduce){.card.pulse{animation:none;opacity:1;transform:none}}

  /* staggered load reveal */
  .rise{opacity:0;transform:translateY(14px);animation:rise .7s cubic-bezier(.2,.7,.2,1) forwards}
  @keyframes rise{to{opacity:1;transform:none}}
  @media(prefers-reduced-motion:reduce){.rise{opacity:1;transform:none;animation:none}}

  /* ---- section heading ---- */
  h2{font-size:clamp(26px,3.4vw,36px);font-weight:700;letter-spacing:-.018em;margin-top:12px}
  .sec-lede{color:var(--muted);font-size:17px;margin-top:14px;max-width:46em}

  /* footer */
  footer{border-top:1px solid var(--hairline-soft);padding:46px 0 70px;margin-top:30px}
  footer .wrap{display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:center}
  footer .lg{font-family:var(--mono);font-weight:700;letter-spacing:.24em;font-size:14px}
  footer .lk{display:flex;gap:22px;font-family:var(--mono);font-size:13px}
  footer a{color:var(--muted);text-decoration:none}
  footer a:hover{color:var(--text)}
  footer .fine{color:var(--faint);font-size:12.5px;margin-top:18px;font-family:var(--mono);line-height:1.7}
</style>
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Agent Andon",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "macOS, Linux, Windows",
  "description": "Open-source status board and alerts for Claude Code and OpenAI Codex. Run several AI coding agents at once and see at a glance which is working, needs you, done, or stuck — on any screen, with optional desktop and phone alerts.",
  "url": "https://agentandon.com/",
  "downloadUrl": "https://www.npmjs.com/package/agent-andon",
  "license": "https://www.gnu.org/licenses/agpl-3.0.html",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "sameAs": ["https://github.com/tianshanghong/agent-andon"]
}
</script>
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I get notified when Claude Code or Codex finishes or needs input?",
      "acceptedAnswer": { "@type": "Answer", "text": "Agent Andon installs lifecycle hooks for Claude Code and OpenAI Codex and shows each session's state — working, needs you, done, or stuck — on a board you can open on any screen, with optional desktop and phone alerts the moment an agent needs you." }
    },
    {
      "@type": "Question",
      "name": "Can I monitor several AI coding agents at once?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Agent Andon shows one row per session and floats whichever needs you to the top, so you can watch several Claude Code or Codex agents at a glance on a wall-mounted iPad, phone, or browser tab." }
    },
    {
      "@type": "Question",
      "name": "Is Agent Andon self-hosted and private?",
      "acceptedAnswer": { "@type": "Answer", "text": "Agent Andon is open-source and self-hosted with zero runtime dependencies; it runs locally with no account and no telemetry. An optional content-blind relay lets you reach the board and get phone push from anywhere, storing only ciphertext it can't decrypt." }
    }
  ]
}
</script>
</head>
<body>
<div class="strip"><i class="e"></i><i class="w"></i><i class="d"></i><i class="k"></i></div>
<div class="grid"></div>

<nav><div class="wrap">
  <div class="logo">🚦 ANDON<span class="dim"> /行灯</span></div>
  <div class="navlinks">
    <a href="#how">{t.navHow}</a>
    <a href="#selfhost">{t.navSelf}</a>
    <a class="star" href="https://github.com/tianshanghong/agent-andon"><svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true" style="vertical-align:-2px;margin-right:5px"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>{t.navStar}</a>
  </div>
</div></nav>

<header class="wrap hero">
  <div>
    <div class="kicker rise" style="animation-delay:.02s" set:html={t.kicker}></div>
    <h1 class="rise" style="animation-delay:.08s" set:html={t.h1}></h1>
    <p class="lede rise" style="animation-delay:.16s" set:html={t.lede}></p>

    <div class="kicker rise" style="animation-delay:.20s;margin-top:32px;color:var(--done)" set:html={t.zero}></div>
    <div class="cmd rise" style="animation-delay:.24s">
      <button id="copy" aria-label={t.copyAria} data-copied={t.copied}>{t.copy}</button>
      <code id="cmd"><span class="p">$</span> npm i -g agent-andon
<span class="p">$</span> andon hosted setup https://relay.agentandon.com
<span class="p">$</span> andon install claude</code>
    </div>
    <div class="hint rise" style="animation-delay:.28s" set:html={t.hint}></div>

    <div class="cta rise" style="animation-delay:.34s">
      <a class="btn ghost" href="https://github.com/tianshanghong/agent-andon"><svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>{t.navStar}</a>
    </div>
  </div>

  <div class="board" aria-hidden="true">
    <div class="card e pulse rise" style="animation-delay:.30s"><div class="st">✕ Stuck</div><div class="nm">data-pipeline</div><div class="msg">tests failing — needs a look</div></div>
    <div class="card w pulse rise" style="animation-delay:.40s"><div class="st">! Needs you</div><div class="nm">ledger-api</div><div class="msg">approve: Bash(git push)</div></div>
    <div class="card d rise" style="animation-delay:.50s"><div class="st">✓ Ready</div><div class="nm">payments-svc</div><div class="msg">turn handed back</div></div>
    <div class="card k rise" style="animation-delay:.60s"><div class="st">↻ Working</div><div class="nm">checkout-api</div><div class="msg">running · 2 background</div></div>
  </div>
</header>

<section id="how" class="wrap">
  <h2>{t.howH2}</h2>
  <p class="sec-lede" set:html={t.howP}></p>
</section>

<section id="selfhost" class="wrap">
  <h2>{t.selfH2}</h2>
  <p class="sec-lede" set:html={t.selfP}></p>
</section>

<footer>
  <div class="wrap">
    <div>
      <div class="lg">🚦 AGENT ANDON</div>
      <div class="fine" set:html={t.ftFine}></div>
    </div>
    <div class="lk">
      <a href="https://github.com/tianshanghong/agent-andon">GitHub</a>
      <a href="https://www.npmjs.com/package/agent-andon">npm</a>
      <a href="https://github.com/tianshanghong/agent-andon/blob/main/docs/running.md">{t.ftDocs}</a>
      <a href="https://github.com/tianshanghong/agent-andon/blob/main/LICENSE">License</a>
    </div>
  </div>
</footer>

<script is:inline>
  // copy the try-command
  var btn=document.getElementById('copy');
  var orig=btn.textContent, done=btn.getAttribute('data-copied');
  btn.addEventListener('click',function(){
    var t='npm i -g agent-andon && andon hosted setup https://relay.agentandon.com && andon install claude';
    (navigator.clipboard?navigator.clipboard.writeText(t):Promise.reject()).then(function(){
      btn.textContent=done;btn.classList.add('ok');
      setTimeout(function(){btn.textContent=orig;btn.classList.remove('ok');},1600);
    }).catch(function(){
      var r=document.createRange();r.selectNodeContents(document.getElementById('cmd'));
      var s=getSelection();s.removeAllRanges();s.addRange(r);
    });
  });
</script>
</body>
</html>
